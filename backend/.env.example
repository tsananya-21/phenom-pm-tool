# Copy to .env and fill in values

# LLM provider: "anthropic" (synthesis runs on Claude)
PHENOM_LLM_PROVIDER=anthropic

# Search provider: "tavily" (live web research)
PHENOM_SEARCH_PROVIDER=tavily

# Required — LLM synthesis runs on Claude
ANTHROPIC_API_KEY=

# Required — live company research runs through Tavily
TAVILY_API_KEY=
