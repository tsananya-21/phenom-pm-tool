# Copy to .env and fill in values

# LLM provider: "ollama" (default, no key needed) or "anthropic"
PHENOM_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest       # or qwen2.5:7b, gemma2:9b

# Search provider: "mock" (default, fully offline) or "tavily"
PHENOM_SEARCH_PROVIDER=mock

# Required only when PHENOM_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Required only when PHENOM_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
